{
  "system_policy_version": "2026.2.0",
  "sca_policy": {
    "fail_on_cve_severity": ["CRITICAL", "HIGH"],
    "allowed_licenses": ["MIT", "Apache-2.0", "BSD-3-Clause"],
    "banned_licenses": ["GPL-3.0", "AGPL-3.0"]
  },
  "sast_policy": {
    "disallowed_patterns": [
      "exec\\(",
      "eval\\(",
      "password\\s*=\\s*['\"][^'\"]+['\"]",
      "secret\\s*=\\s*['\"][^'\"]+['\"]",
      "api_key\\s*=\\s*['\"][^'\"]+['\"]",
      "cursor\\.execute\\(f?['\"].*\\{.*\}.*['\"]\\)",
      "subprocess\\.Popen\\(.*shell=True.*\\)",
      "os\\.system\\("
    ]
  },
  "dockerfile_policy": {
    "disallowed_base_registries_regex": "^FROM\\s+(?!docker\\.io/library/|python:|alpine:|ubuntu:|debian:)[\\w\\.-]+/[\\w\\.-]+",
    "enforce_user_declaration": true,
    "block_root_execution": true,
    "require_healthcheck": true,
    "forbidden_instructions": [
      "SSH",
      "apt-get install -y --no-install-recommends"
    ]
  }
}
