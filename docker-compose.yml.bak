services:
  # Local Model Server
  ollama-server:
    image: ollama/ollama:latest
    container_name: ollama-core
    volumes:
      - ollama-data:/root/.ollama
    ports:
      - "11434:11434"
    environment:
      - OLLAMA_NUM_PARALLEL=4
    networks:
      - secure-agent-mesh
      - internet-ingress

  # Standalone HTTP Voice Synthesis Engine (Piper HTTP Wrapper Mode)
  piper-server:
    image: rhasspy/wyoming-piper:latest
    container_name: piper-core
    volumes:
      - ./workspace:/data
    ports:
      - "10200:10200"
    # Command configures the built-in HTTP web server mapping directly
    command: --voice en_US-lessac-medium --uri http://0.0.0 --data-dir /data --download-dir /data/voices
    networks:
      - secure-agent-mesh
      - internet-ingress

  # The Air-Gapped Multi-Agent Orchestrator
  agent-orchestrator:
    build:
      context: ./orchestrator
      dockerfile: Dockerfile
    container_name: agent-orchestrator-core
    ports:
      - "8000:8000"
    volumes:
      - ./manifest:/app/manifest:ro
      - ./workspace:/app/workspace
    environment:
      - OLLAMA_HOST=http://ollama-server:11434
      - PIPER_HOST=http://piper-server:10200
    depends_on:
      - ollama-server
      - piper-server
    networks:
      - secure-agent-mesh
      - public-ingress

networks:
  secure-agent-mesh:
    driver: bridge
    internal: true
  internet-ingress:
    driver: bridge
  public-ingress:
    driver: bridge

volumes:
  ollama-data:
